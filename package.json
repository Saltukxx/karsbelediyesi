{
  "name": "kars-belediyesi",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:bot": "npm run dev --workspace=apps/whatsapp-bot",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:push": "npm run push --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:import": "npm run import --workspace=packages/db --",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}
