# Veritabanı
DATABASE_URL="postgresql://kars:kars_dev_sifre@localhost:5432/kars_belediyesi"

# Redis (BullMQ kuyruk + WhatsApp oturum durumu)
REDIS_URL="redis://localhost:6379"

# Auth.js
AUTH_SECRET="degistir-uzun-rastgele-bir-anahtar"
AUTH_URL="http://localhost:3000"

# Mobil JWT
JWT_SECRET="degistir-mobil-jwt-anahtari"

# Gemini API (WhatsApp mesaj sınıflandırma + fine-tune)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Few-shot count from gold.jsonl (fine-tune yok). Varsayılan 12.
GEMINI_FEW_SHOT="12"
# Fine-tune job bitince doldurun (örn. tunedModels/kars-sikayet-xxx)
GEMINI_TUNED_MODEL=""

# WhatsApp botu
WHATSAPP_AUTO_CONFIDENCE_THRESHOLD="0.75"

# Dosya yükleme dizini
UPLOAD_DIR="./uploads"
